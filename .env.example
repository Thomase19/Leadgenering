# Database (use with docker-compose postgres)
DATABASE_URL="postgresql://leadbot:leadbot@localhost:5432/leadbot"

# Redis (use with docker-compose redis)
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"

# Optional: hash IPs with a salt (GDPR)
IP_HASH_SALT="your-random-salt"

# OpenAI (required for AI responses)
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# Public URL for widget snippet and webhook transcript links
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# HubSpot (optional, for HubSpot integration)
# HUBSPOT_CLIENT_ID=
# HUBSPOT_CLIENT_SECRET=
